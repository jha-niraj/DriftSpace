{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"DATABASE_URL",
		"NEXTAUTH_URL",
		"NEXTAUTH_SECRET",
		"RESEND_API_KEY",
		"CLOUDINARY_CLOUD_NAME",
		"CLOUDINARY_API_KEY",
		"CLOUDINARY_API_SECRET"
	],
	"tasks": {
		"generate": {
			"cache": false,
			"inputs": [
				"prisma/schema.prisma"
			],
			"outputs": [
				"../../node_modules/.prisma/client/**"
			]
		},
		"build": {
			"dependsOn": [
				"^generate",
				"^build"
			],
			"env": [
				"NODE_ENV",
				"DATABASE_URL",
				"NEXTAUTH_URL",
				"NEXTAUTH_SECRET",
				"RESEND_API_KEY",
				"CLOUDINARY_CLOUD_NAME",
				"CLOUDINARY_API_KEY",
				"CLOUDINARY_API_SECRET"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"env": [
				"NODE_ENV",
				"DATABASE_URL",
				"NEXTAUTH_URL",
				"NEXTAUTH_SECRET",
				"RESEND_API_KEY",
				"CLOUDINARY_CLOUD_NAME",
				"CLOUDINARY_API_KEY",
				"CLOUDINARY_API_SECRET"
			]
		}
	}
}